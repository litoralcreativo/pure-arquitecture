### Variables
@baseUrl = http://localhost:3000
@customerId1 = c1
@customerId2 = c2
@productId1 = p1
@productId2 = p2
@coupon10 = DESCUENTO10
@coupon20 = DESCUENTO20
@couponFixed50 = VERANO50
@couponFixed100 = PRIMERACOMPRA
@couponExpired = VERANO98

###############################################
# Clean Architecture - Cart API Tests
###############################################

### 1. Crear Carrito para Cliente 1
# Crea un nuevo carrito para el cliente c1
POST {{baseUrl}}/cart HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}"
}

###

### 2. Obtener Carrito (Vacío)
# Obtiene el carrito actual - debería estar vacío o no existir aún
GET {{baseUrl}}/cart/{{customerId1}} HTTP/1.1

###

### 3. Agregar Producto p1 al Carrito (Primera vez)
# Agrega el producto p1 al carrito de c1
POST {{baseUrl}}/cart/add-product HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "productId": "{{productId1}}"
}

###

### 4. Obtener Carrito (Con 1 producto)
# Debería mostrar p1 con cantidad 1
GET {{baseUrl}}/cart/{{customerId1}} HTTP/1.1

###

### 5. Agregar el Mismo Producto p1 (Segunda vez)
# Incrementa la cantidad del producto p1 existente
POST {{baseUrl}}/cart/add-product HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "productId": "{{productId1}}"
}

###

### 6. Obtener Carrito (Con cantidad 2 de p1)
# Debería mostrar p1 con cantidad 2
GET {{baseUrl}}/cart/{{customerId1}} HTTP/1.1

###

### 7. Agregar Producto p2
# Agrega un segundo producto diferente
POST {{baseUrl}}/cart/add-product HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "productId": "{{productId2}}"
}

###

### 8. Obtener Carrito (Con 2 productos: p1 y p2)
# Debería mostrar p1 (cant: 2) y p2 (cant: 1)
GET {{baseUrl}}/cart/{{customerId1}} HTTP/1.1

###

### 9. Incrementar Cantidad de p1
# Incrementa la cantidad de p1 (de 2 a 3)
PATCH {{baseUrl}}/cart/increase-quantity HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "productId": "{{productId1}}"
}

###

### 10. Obtener Carrito (Después de incrementar p1)
# Debería mostrar p1 (cant: 3) y p2 (cant: 1)
GET {{baseUrl}}/cart/{{customerId1}} HTTP/1.1

###

### 11. Decrementar Cantidad de p1
# Decrementa la cantidad de p1 (de 3 a 2)
PATCH {{baseUrl}}/cart/decrease-quantity HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "productId": "{{productId1}}"
}

###

### 12. Obtener Carrito (Después de decrementar p1)
# Debería mostrar p1 (cant: 2) y p2 (cant: 1)
GET {{baseUrl}}/cart/{{customerId1}} HTTP/1.1

###

### 13. Remover Producto p1 del Carrito
# Elimina completamente el producto p1
DELETE {{baseUrl}}/cart/remove-product HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "productId": "{{productId1}}"
}

###

### 14. Obtener Carrito Final de c1
# Debería mostrar solo p2 con cantidad 1
GET {{baseUrl}}/cart/{{customerId1}} HTTP/1.1

###

###############################################
# Tests con Cliente 2 (c2)
###############################################

### 15. Crear Carrito para Cliente 2 (c2)
POST {{baseUrl}}/cart HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId2}}"
}

###

### 16. Agregar Producto p1 al Carrito de c2
POST {{baseUrl}}/cart/add-product HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId2}}",
  "productId": "{{productId1}}"
}

###

### 17. Agregar Producto p2 al Carrito de c2
POST {{baseUrl}}/cart/add-product HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId2}}",
  "productId": "{{productId2}}"
}

###

### 18. Obtener Carrito del Cliente 2 (c2)
# Debería mostrar p1 y p2, ambos con cantidad 1
GET {{baseUrl}}/cart/{{customerId2}} HTTP/1.1

###

### 19. Verificar Aislamiento - Obtener Carrito de c1
# El carrito de c1 debe tener solo p2
# El carrito de c2 debe tener p1 y p2
GET {{baseUrl}}/cart/{{customerId1}} HTTP/1.1

###

### 20. Incrementar p1 en el carrito de c2
PATCH {{baseUrl}}/cart/increase-quantity HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId2}}",
  "productId": "{{productId1}}"
}

###

### 21. Obtener Carrito de c2 (con p1 incrementado)
# Debería mostrar p1 (cant: 2) y p2 (cant: 1)
GET {{baseUrl}}/cart/{{customerId2}} HTTP/1.1

###

###############################################
# Tests de Casos de Error
###############################################

### 22. Error - Crear Carrito Duplicado (c1 ya existe)
# Intentar crear un carrito que ya existe
POST {{baseUrl}}/cart HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}"
}

###

### 23. Error - Obtener Carrito Inexistente (c3)
# Intentar obtener un carrito que no existe
GET {{baseUrl}}/cart/c3 HTTP/1.1

###

### 24. Error - Agregar Producto a Carrito Inexistente (c3)
POST {{baseUrl}}/cart/add-product HTTP/1.1
Content-Type: application/json

{
  "customerId": "c3",
  "productId": "{{productId1}}"
}

###

### 25. Error - Producto Inexistente (p9)
POST {{baseUrl}}/cart/add-product HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "productId": "p9"
}

###

### 26. Error - Remover Producto que No Está en el Carrito
# p1 ya fue removido del carrito de c1
DELETE {{baseUrl}}/cart/remove-product HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "productId": "{{productId1}}"
}

###

### 27. Error - Incrementar Cantidad de Producto No Existente (p9)
PATCH {{baseUrl}}/cart/increase-quantity HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "productId": "p9"
}

###

### 28. Error - Decrementar Cantidad de Producto No Existente (p9)
PATCH {{baseUrl}}/cart/decrease-quantity HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "productId": "p9"
}

###

###############################################
# Flujo Completo - Cliente c2 comprando p1 y p2
###############################################

### 29. Incrementar p2 en carrito de c2
PATCH {{baseUrl}}/cart/increase-quantity HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId2}}",
  "productId": "{{productId2}}"
}

###

### 30. Incrementar p2 nuevamente en carrito de c2
PATCH {{baseUrl}}/cart/increase-quantity HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId2}}",
  "productId": "{{productId2}}"
}

###

### 31. Ver Carrito Final de c2 con Totales
# Debería mostrar p1 (cant: 2) y p2 (cant: 3)
GET {{baseUrl}}/cart/{{customerId2}} HTTP/1.1

###

### 32. Resumen - Ver ambos carritos

# Carrito de c1 (solo p2)
GET {{baseUrl}}/cart/{{customerId1}} HTTP/1.1

###

# Carrito de c2 (p1 x2 y p2 x3)
GET {{baseUrl}}/cart/{{customerId2}} HTTP/1.1

###

###############################################
# Limpiar - Decrementar hasta eliminar
###############################################

### 33. Decrementar p2 en c1 hasta eliminarlo
PATCH {{baseUrl}}/cart/decrease-quantity HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "productId": "{{productId2}}"
}

###

### 34. Verificar que p2 fue eliminado de c1 (carrito vacío)
GET {{baseUrl}}/cart/{{customerId1}} HTTP/1.1

###

###############################################
# Tests de Cupones de Descuento
###############################################

### 35. Preparar carrito de c1 para pruebas de cupones
# Agregar 2 productos p1 (Laptop $1000 c/u = $2000)
POST {{baseUrl}}/cart/add-product HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "productId": "{{productId1}}"
}

###

### 36. Agregar segundo p1
POST {{baseUrl}}/cart/add-product HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "productId": "{{productId1}}"
}

###

### 37. Ver carrito antes de aplicar cupón
# Debería mostrar: subtotal: $2000, discount: $0, total: $2000
GET {{baseUrl}}/cart/{{customerId1}} HTTP/1.1

###

### 38. Aplicar Cupón Porcentual 10% (DESCUENTO10)
# Descuento: 10% de $2000 = $200
# Total esperado: $1800
POST {{baseUrl}}/cart/apply-coupon HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "couponCode": "{{coupon10}}"
}

###

### 39. Ver carrito con cupón 10% aplicado
# Esperado: subtotal: $2000, discount: $200, couponCode: "DESCUENTO10", total: $1800
GET {{baseUrl}}/cart/{{customerId1}} HTTP/1.1

###

### 40. Error - Aplicar Segundo Cupón (ya tiene uno aplicado)
# Debe rechazar porque ya tiene DESCUENTO10 aplicado
POST {{baseUrl}}/cart/apply-coupon HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "couponCode": "{{coupon20}}"
}

###

### 41. Remover Cupón del Carrito
# Debe remover DESCUENTO10 y recalcular totales
DELETE {{baseUrl}}/cart/remove-coupon HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}"
}

###

### 42. Ver carrito sin cupón
# Esperado: subtotal: $2000, discount: $0, total: $2000
GET {{baseUrl}}/cart/{{customerId1}} HTTP/1.1

###

### 43. Aplicar Cupón 20% con mínimo $500 (DESCUENTO20)
# Subtotal $2000 cumple el mínimo
# Descuento: 20% de $2000 = $400
# Total esperado: $1600
POST {{baseUrl}}/cart/apply-coupon HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "couponCode": "{{coupon20}}"
}

###

### 44. Ver carrito con cupón 20% aplicado
# Esperado: subtotal: $2000, discount: $400, couponCode: "DESCUENTO20", total: $1600
GET {{baseUrl}}/cart/{{customerId1}} HTTP/1.1

###

### 45. Remover cupón para probar cupones de monto fijo
DELETE {{baseUrl}}/cart/remove-coupon HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}"
}

###

### 46. Aplicar Cupón Fijo $50 (VERANO50)
# Mínimo: $200 ✓ (cumple con $2000)
# Descuento: $50 fijo
# Total esperado: $1950
POST {{baseUrl}}/cart/apply-coupon HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "couponCode": "{{couponFixed50}}"
}

###

### 47. Ver carrito con cupón fijo $50
# Esperado: subtotal: $2000, discount: $50, couponCode: "VERANO50", total: $1950
GET {{baseUrl}}/cart/{{customerId1}} HTTP/1.1

###

### 48. Remover cupón y aplicar cupón de $100
DELETE {{baseUrl}}/cart/remove-coupon HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}"
}

###

### 49. Aplicar Cupón Fijo $100 (PRIMERACOMPRA)
# Mínimo: $300 ✓ (cumple con $2000)
# Descuento: $100 fijo
# Total esperado: $1900
POST {{baseUrl}}/cart/apply-coupon HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "couponCode": "{{couponFixed100}}"
}

###

### 50. Ver carrito con cupón fijo $100
# Esperado: subtotal: $2000, discount: $100, couponCode: "PRIMERACOMPRA", total: $1900
GET {{baseUrl}}/cart/{{customerId1}} HTTP/1.1

