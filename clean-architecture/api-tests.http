### 70. Ver carrito de c2 con cupón 20%
# Esperado: subtotal: $1025, discount: $205, total: $820
GET {{baseUrl}}/cart/{{customerId2}} HTTP/1.1

###

### 71. Agregar más productos (el cupón debe seguir aplicado)
POST {{baseUrl}}/cart/add-product HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId2}}",
  "productId": "{{productId1}}"
}

###

### 72. Ver carrito de c2 después de agregar producto
# p1 x2 ($2000) + p2 ($25) = $2025
# Descuento: 20% de $2025 = $405
# Total: $1620
GET {{baseUrl}}/cart/{{customerId2}} HTTP/1.1

###

### 73. Decrementar producto (el cupón debe recalcularse)
PATCH {{baseUrl}}/cart/decrease-quantity HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId2}}",
  "productId": "{{productId1}}"
}

###

### 74. Ver carrito después de decrementar (cupón recalculado)
# p1 ($1000) + p2 ($25) = $1025
# Descuento: 20% de $1025 = $205
# Total: $820
GET {{baseUrl}}/cart/{{customerId2}} HTTP/1.1

