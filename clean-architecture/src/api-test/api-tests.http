### 101. Consultar Detalle de Purchase Específica
# Reemplazar {purchaseId} con un ID real del historial
# Ejemplo: GET {{baseUrl}}/purchases/pur-1234567890/customer/c1
# Por ahora, este test fallará hasta que se obtenga un purchaseId real
GET {{baseUrl}}/purchases/pur-example-id/customer/{{customerId1}} HTTP/1.1

###

### 102. Error - Consultar Purchase Inexistente
GET {{baseUrl}}/purchases/pur-99999/customer/{{customerId1}} HTTP/1.1

###

### 103. Error - Purchase de Otro Cliente (validación de propiedad)
# Intentar que c2 acceda a una purchase de c1
# Reemplazar {purchaseId-de-c1} con un ID real de c1
GET {{baseUrl}}/purchases/pur-example-id/customer/{{customerId2}} HTTP/1.1

###

###############################################
# Flujo Completo: Checkout con Múltiples Compras
###############################################

### 104. Crear tercer carrito para c1
POST {{baseUrl}}/cart HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}"
}

###

### 105. Agregar múltiples productos a c1
POST {{baseUrl}}/cart/add-product HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "productId": "{{productId1}}"
}

###

### 106. Incrementar p1 en c1
PATCH {{baseUrl}}/cart/increase-quantity HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "productId": "{{productId1}}"
}

###

### 107. Incrementar p1 nuevamente en c1
PATCH {{baseUrl}}/cart/increase-quantity HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "productId": "{{productId1}}"
}

###

### 108. Agregar p2 a c1
POST {{baseUrl}}/cart/add-product HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "productId": "{{productId2}}"
}

###

### 109. Incrementar p2 en c1
PATCH {{baseUrl}}/cart/increase-quantity HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "productId": "{{productId2}}"
}

###

### 110. Aplicar cupón de monto fijo $100
POST {{baseUrl}}/cart/apply-coupon HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "couponCode": "{{couponFixed100}}"
}

###

### 111. Ver carrito final de c1 antes de checkout
# Esperado: p1 x3 ($3000) + p2 x2 ($50) = $3050
# Descuento: $100 fijo
# Total: $2950
GET {{baseUrl}}/cart/{{customerId1}} HTTP/1.1

###

### 112. Tercer Checkout de c1
POST {{baseUrl}}/checkout HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}"
}

###

### 113. Historial Final de c1 (debe tener 3 compras)
# Ordenadas por fecha descendente
GET {{baseUrl}}/purchases/history/{{customerId1}} HTTP/1.1

###

###############################################
# Verificación de Aislamiento de Purchases
###############################################

### 114. Verificar que c2 solo ve su historial (1 compra)
GET {{baseUrl}}/purchases/history/{{customerId2}} HTTP/1.1

###

### 115. Verificar que c3 solo ve su historial (1 compra)
GET {{baseUrl}}/purchases/history/c3 HTTP/1.1

###

### 116. Cliente sin compras (c4 - nunca existió)
GET {{baseUrl}}/purchases/history/c4 HTTP/1.1

###

###############################################
# Resumen Final del Sistema
###############################################

### 117. Resumen - Total de compras en el sistema
# c1: 3 compras
# c2: 1 compra
# c3: 1 compra
# Total: 5 purchases creadas

# Historial c1
GET {{baseUrl}}/purchases/history/{{customerId1}} HTTP/1.1

###

# Historial c2
GET {{baseUrl}}/purchases/history/{{customerId2}} HTTP/1.1

###

# Historial c3
GET {{baseUrl}}/purchases/history/c3 HTTP/1.1

