###############################################
# Tests de Cupones de Descuento
###############################################

### 35. Preparar carrito de c1 para pruebas de cupones
# Agregar 2 productos p1 (Laptop $1000 c/u = $2000)
POST {{baseUrl}}/cart/add-product HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "productId": "{{productId1}}"
}

###

### 36. Agregar segundo p1
POST {{baseUrl}}/cart/add-product HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "productId": "{{productId1}}"
}

###

### 37. Ver carrito antes de aplicar cupón
# Debería mostrar: subtotal: $2000, discount: $0, total: $2000
GET {{baseUrl}}/cart/{{customerId1}} HTTP/1.1

###

### 38. Aplicar Cupón Porcentual 10% (DESCUENTO10)
# Descuento: 10% de $2000 = $200
# Total esperado: $1800
POST {{baseUrl}}/cart/apply-coupon HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "couponCode": "{{coupon10}}"
}

###

### 39. Ver carrito con cupón 10% aplicado
# Esperado: subtotal: $2000, discount: $200, couponCode: "DESCUENTO10", total: $1800
GET {{baseUrl}}/cart/{{customerId1}} HTTP/1.1

###

### 40. Error - Aplicar Segundo Cupón (ya tiene uno aplicado)
# Debe rechazar porque ya tiene DESCUENTO10 aplicado
POST {{baseUrl}}/cart/apply-coupon HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}",
  "couponCode": "{{coupon20}}"
}

###

### 41. Remover Cupón del Carrito
# Debe remover DESCUENTO10 y recalcular totales
DELETE {{baseUrl}}/cart/remove-coupon HTTP/1.1
Content-Type: application/json

{
  "customerId": "{{customerId1}}"
}

###

### 42. Ver carrito sin cupón
# Esperado: subtotal: $2000, discount: $0, total: $2000
GET {{baseUrl}}/cart/{{customerId1}} HTTP/1.1

###

### 43. Aplicar Cupón 20% con mínimo $500 (DESCUENTO20)
